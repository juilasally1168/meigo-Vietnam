<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>旅遊行程表</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      min-height: 100vh;
      background-image: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), 
                        url("https://cdn.phototourl.com/free/2026-07-11-a9c187d1-3973-49f5-b6e9-ef2a31943904.jpg");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      color: #ffffff;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      padding: 20px 12px;
    }
    .container {
      max-width: 800px;
      margin: 0 auto;
      background-color: rgba(18, 18, 18, 0.75);
      padding: 24px;
      border-radius: 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    }
    .title {
      text-align: center;
      color: #ffd166;
      font-size: 1.8rem;
      margin-bottom: 8px;
    }
    .date-range {
      text-align: center;
      opacity: 0.85;
      font-size: 0.95rem;
      margin-bottom: 24px;
    }
    .day-card {
      margin-bottom: 28px;
      background-color: rgba(255, 255, 255, 0.08);
      padding: 16px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .day-title {
      border-bottom: 2px solid #ffd166;
      padding-bottom: 8px;
      color: #ffd166;
      font-size: 1.3rem;
      margin-bottom: 12px;
    }
    .spot-item {
      margin: 12px 0;
      padding: 12px;
      background-color: rgba(0, 0, 0, 0.35);
      border-radius: 8px;
    }
    .spot-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: bold;
      margin-bottom: 6px;
    }
    .spot-name {
      font-size: 1.05rem;
      color: #4ecdc4;
    }
    .spot-stay {
      font-size: 0.85rem;
      opacity: 0.8;
      background: rgba(255, 255, 255, 0.15);
      padding: 2px 8px;
      border-radius: 12px;
    }
    .spot-desc {
      font-size: 0.95rem;
      line-height: 1.4;
      margin-top: 4px;
      color: #f0f0f0;
    }
    .spot-detail {
      font-size: 0.85rem;
      line-height: 1.4;
      margin-top: 6px;
      color: #dddddd;
      background: rgba(255, 209, 102, 0.1);
      padding: 6px 10px;
      border-left: 3px solid #ffd166;
      border-radius: 0 4px 4px 0;
    }
    .status-msg {
      text-align: center;
      padding: 40px 20px;
      font-size: 1.2rem;
    }
  </style>
</head>
<body>

  <div id="app" class="container">
    <div class="status-msg">行程資料載入中...</div>
  </div>

  <script>
    (function() {
      const appDiv = document.getElementById('app');

      try {
        const hash = window.location.hash;
        if (!hash || !hash.includes('t=')) {
          appDiv.innerHTML = '<div class="status-msg" style="color: #ff6b6b;">⚠️ 未檢測到行程資料，請確認網址是否包含資料標籤！</div>';
          return;
        }

        const token = hash.split('t=')[1];
        
        // Base64 UTF-8 解碼處理
        const jsonString = decodeURIComponent(
          atob(token)
            .split('')
            .map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2))
            .join('')
        );

        const data = JSON.parse(jsonString);

        if (!data || !data.days) {
          appDiv.innerHTML = '<div class="status-msg" style="color: #ff6b6b;">⚠️ 行程資料格式不正確！</div>';
          return;
        }

        // 開始渲染 HTML
        let html = `
          <h1 class="title">${data.title || "越南旅遊行程"}</h1>
          <div class="date-range">📅 出發日期：${data.start || ''} ～ ${data.end || ''}</div>
        `;

        data.days.forEach((day, dIdx) => {
          html += `
            <div class="day-card">
              <h2 class="day-title">${day.title || 'Day ' + (dIdx + 1)}</h2>
          `;

          if (day.spots && day.spots.length > 0) {
            day.spots.forEach(spot => {
              html += `
                <div class="spot-item">
                  <div class="spot-header">
                    <span class="spot-name">📍 ${spot.time || ''} ${spot.n || ''}</span>
                    ${spot.stay ? `<span class="spot-stay">${spot.stay}</span>` : ''}
                  </div>
                  ${spot.desc ? `<div class="spot-desc">${spot.desc}</div>` : ''}
                  ${spot.detail ? `<div class="spot-detail">💡 ${spot.detail}</div>` : ''}
                </div>
              `;
            });
          }

          html += `</div>`;
        });

        appDiv.innerHTML = html;

      } catch (err) {
        console.error("解析失敗:", err);
        appDiv.innerHTML = '<div class="status-msg" style="color: #ff6b6b;">⚠️ 行程資料解析失敗，請確認網址是否完整！</div>';
      }
    })();
  </script>
</body>
</html>

import React, { useState, useEffect } from 'react';

export default function App() {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  useEffect(() => {
    try {
      const hash = window.location.hash;
      if (hash && hash.includes('t=')) {
        const token = hash.split('t=')[1];
        // 解碼 Base64 資料 (支援 UTF-8 中文)
        const jsonString = decodeURIComponent(
          atob(token)
            .split('')
            .map((c) => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2))
            .join('')
        );
        const parsedData = JSON.parse(jsonString);
        setData(parsedData);
      }
      setLoading(false);
    } catch (err) {
      console.error("解析失敗:", err);
      setError("行程資料解析失敗，請確認網址是否完整！");
      setLoading(false);
    }
  }, []);

  if (loading) {
    return (
      <div style={{ padding: '40px', textAlign: 'center', color: '#fff' }}>
        <h2>行程載入中...</h2>
      </div>
    );
  }

  if (error) {
    return (
      <div style={{ padding: '40px', textAlign: 'center', color: '#ff6b6b' }}>
        <h2>⚠️ {error}</h2>
      </div>
    );
  }

  if (!data) {
    return (
      <div style={{ padding: '40px', textAlign: 'center', color: '#fff' }}>
        <h2>未找到行程資料</h2>
      </div>
    );
  }

  return (
    <div
      style={{
        minHeight: '100vh',
        backgroundImage: `linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url("https://cdn.phototourl.com/free/2026-07-11-a9c187d1-3973-49f5-b6e9-ef2a31943904.jpg")`,
        backgroundSize: 'cover',
        backgroundPosition: 'center',
        backgroundAttachment: 'fixed',
        color: '#ffffff',
        fontFamily: 'system-ui, -apple-system, sans-serif',
        padding: '20px'
      }}
    >
      <div style={{ maxWidth: '800px', margin: '0 auto', backgroundColor: 'rgba(0, 0, 0, 0.65)', padding: '24px', borderRadius: '16px', backdropFilter: 'blur(8px)' }}>
        <h1 style={{ textAlign: 'center', color: '#ffd166', marginBottom: '8px' }}>
          {data.title || "越南旅遊行程"}
        </h1>
        <p style={{ textAlign: 'center', opacity: 0.8, marginBottom: '24px' }}>
          出發日期：{data.start} ～ {data.end}
        </p>

        {data.days && data.days.map((day, dIdx) => (
          <div key={dIdx} style={{ marginBottom: '32px', backgroundColor: 'rgba(255, 255, 255, 0.1)', padding: '16px', borderRadius: '12px' }}>
            <h2 style={{ borderBottom: '2px solid #ffd166', paddingBottom: '8px', color: '#ffd166' }}>
              {day.title || `Day ${dIdx + 1}`}
            </h2>

            {day.spots && day.spots.map((spot, sIdx) => (
              <div key={sIdx} style={{ margin: '16px 0', padding: '12px', backgroundColor: 'rgba(0, 0, 0, 0.3)', borderRadius: '8px' }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', fontWeight: 'bold' }}>
                  <span style={{ fontSize: '1.1em', color: '#4ecdc4' }}>{spot.time} {spot.n}</span>
                  <span style={{ fontSize: '0.9em', opacity: 0.8 }}>停留：{spot.stay}</span>
                </div>
                {spot.desc && <p style={{ margin: '8px 0 4px 0', fontSize: '0.95em' }}>{spot.desc}</p>}
                {spot.detail && <p style={{ margin: '4px 0', fontSize: '0.85em', color: '#ddd' }}>💡 {spot.detail}</p>}
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  );
}
